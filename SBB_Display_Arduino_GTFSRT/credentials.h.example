/**
 * credentials.h
 *
 * Fill in your WiFi credentials, your GTFS-RT / OJP API key and the list of
 * GTFS stop IDs you want to cycle through with the button.
 *
 * --------------------------------------------------------------------------
 * How to get a GTFS-RT / OJP API key
 * --------------------------------------------------------------------------
 * 1. Register at https://api-manager.opentransportdata.swiss/
 * 2. Create an Application.
 * 3. Subscribe to BOTH:
 *      - "GTFS-RT" API  (real-time departures)
 *      - "OJP"     API  (nearest-stop GPS lookup)
 *    Both use the same Bearer token.
 * 4. Copy the Bearer token into GTFS_RT_API_KEY below.
 *
 * --------------------------------------------------------------------------
 * GPS module wiring
 * --------------------------------------------------------------------------
 * The sketch uses Hardware Serial 1 (GPS_SERIAL = Serial1) at 9600 baud.
 * Default pins (change GPS_RX_PIN / GPS_TX_PIN in the .ino if needed):
 *   ESP32-S3 GPIO 44  ←  GPS module TX
 *   ESP32-S3 GPIO 43  →  GPS module RX  (only needed if you send to the GPS)
 *
 * --------------------------------------------------------------------------
 * How to find GTFS stop IDs for your stations
 * --------------------------------------------------------------------------
 * Download the current GTFS static package:
 *   https://data.opentransportdata.swiss/dataset/timetable-2026-gtfs2020
 * Open stops.txt (CSV) and search for your station name.
 * The first column ("stop_id") is the value to put in STOP_IDS[].
 *
 * Common examples:
 *   8503000  Zürich HB
 *   8507000  Bern
 *   8500010  Basel SBB
 *   8506000  Luzern
 *   8501120  Winterthur
 */

#pragma once

// ---------------------------------------------------------------------------
// WiFi
// ---------------------------------------------------------------------------
const char *ssid     = "YOUR_WIFI_SSID";
const char *password = "YOUR_WIFI_PASSWORD";

// ---------------------------------------------------------------------------
// opentransportdata.swiss API key (Bearer token) – used for GTFS-RT AND OJP
// ---------------------------------------------------------------------------
const char *GTFS_RT_API_KEY = "YOUR_BEARER_TOKEN_HERE";

// ---------------------------------------------------------------------------
// Fallback stops to cycle through when no GPS fix is available
// (button cycles stationIndex through this list)
//
// Add or remove entries as needed.  Keep STOP_IDS and STOP_NAMES in sync.
// ---------------------------------------------------------------------------
const int NUM_STOPS = 4;

// GTFS stop_id values from stops.txt
const char *STOP_IDS[NUM_STOPS] = {
  "8503000",  // Zürich HB
  "8507000",  // Bern
  "8500010",  // Basel SBB
  "8506000",  // Luzern
};

// Human-readable names shown on the display header
const char *STOP_NAMES[NUM_STOPS] = {
  "Zürich HB",
  "Bern",
  "Basel SBB",
  "Luzern",
};
