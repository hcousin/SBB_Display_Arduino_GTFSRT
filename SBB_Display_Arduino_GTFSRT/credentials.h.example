/**
 * credentials.h
 *
 * Copy this file to credentials.h and fill in your values.
 * credentials.h is gitignored to protect your API key and WiFi password.
 *
 * --------------------------------------------------------------------------
 * How to get an OJP API key
 * --------------------------------------------------------------------------
 * 1. Register at https://api-manager.opentransportdata.swiss/
 * 2. Create an Application named e.g. "SBB-EPaper-Display"
 * 3. Subscribe to the "OJP" API (Default Key plan)
 * 4. Copy the Bearer token into OJP_API_KEY below
 *
 * --------------------------------------------------------------------------
 * GPS module wiring (optional – falls back to default coords if no fix)
 * --------------------------------------------------------------------------
 *   ESP32-S3 GPIO 44  ←  GPS module TX
 *   ESP32-S3 GPIO 43  →  GPS module RX
 */

#pragma once

// WiFi
const char *ssid        = "YOUR_WIFI_SSID";
const char *password    = "YOUR_WIFI_PASSWORD";

// OJP Bearer token (used for LocationInformationRequest + StopEventRequest)
const char *OJP_API_KEY = "YOUR_BEARER_TOKEN_HERE";
